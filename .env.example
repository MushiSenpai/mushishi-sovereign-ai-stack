# Mushishi Sovereign AI Stack — environment template
# Copy to the locations noted; never commit real values.

# ── LiteLLM proxy (configs/litellm/run.env) ──────────────────────────────────
LITELLM_MASTER_KEY=sk-generate-a-long-random-string
DATABASE_URL=postgresql://litellm:CHANGE_ME@litellm-postgres:5432/litellm
NGC_API_KEY=nvapi-your-nvidia-build-key           # Kimi K2.6 via build.nvidia.com
GROQ_API_KEY=gsk_your-groq-key                    # free tier: 14.4k req/day
OPENROUTER_API_KEY=sk-or-your-openrouter-key      # paid backstop
DEEPSEEK_API_KEY=sk-your-deepseek-key             # optional

# ── HuggingFace (model downloads) ────────────────────────────────────────────
HF_TOKEN=hf_your-read-scope-token

# ── Hermes agent (~/.hermes/.env AND each profile's .env — see LESSONS.md
#    on profile .env precedence) ─────────────────────────────────────────────
HERMES_PASSWORD=choose-a-strong-password
HERMES_DASHBOARD_SESSION_TOKEN=pin-a-stable-random-token   # or remote pairing breaks on restart

# ── Watchdog (scripts/healthcheck.sh) ────────────────────────────────────────
# ntfy topic = a credential. Generate: echo "myhost-alerts-$(openssl rand -hex 5)"
NTFY_TOPIC=your-unguessable-topic-here
